<!-- ================= 자바스크립트 엔진 통합 ================= -->
<script>
const BOARD_SIZE = 7;
const icons = [
"https://lh3.googleusercontent.com/aida-public/AB6AXuCKcVthOwWG2a0LVmwpM7qTzkslVKeH5rbfeCMd42oyJmKkelaaq8CiI8e0XmI3dAF99a9wZ9LWqDr90rtY281kldMUEl4CjXi2XNHu494hClvTrkuPz-U2FkW-oWAhdijlYEDQqcC7sIRQCyWCRNsD5xlrASqvXFKYpvjtxxW2qPvaaw_I4aSZOXr0F2TTwbO8UHFcqE98eyf2g7qLLSr_ZS96mePeExE3Xjy1kWXtOzN5bgTssw4_JzbmTqnVsXbWN0Q-p2XrBhA",
"https://lh3.googleusercontent.com/aida-public/AB6AXuB4LuECFtNq0J-6IsrvhvLQuit5dSyBgsUlsQWgj3wNRBU3daoE0aSNMZj6jfiJmq1djzINFFS77SWQwza_EDcsDvhDDSX_SmWI_hVaf_z5ZXdzYj7FePuwLqxH3yk87HQ7h0-rYkEuAl-9e3Sfl9Wizzk9fSpETWQ2MUOswgR1-Zfy_qhM8cfcKJ-Nb6I6wpQMhV4Uu6-cjL--InQFeS6N2f3nrfYZOValzZwRc-yZqVnBDMVbUnEeMCqYwzpDule3vO6Q-qz6rWY",
"https://lh3.googleusercontent.com/aida-public/AB6AXuDrHyLIzRetXwBbmSKCXPEjUduwmX1HdQgCV2lwd6eDi_Ku16x8ElQyvV_XGn5ljhLmEeEbA6cPzylespp-9W70lNeLS2F8y7PwX6WSJhxYOAQEAa_hgG2JAVOXKfQuCwWtmyn4Ki4Q3qiyTZyOoFiKWNPTqVHNbcLm15CUnjxBfCL1RuHgUWs70kmX2q-INZDb_vw5etjPtIAMlO2TljNdKBD9HHs3xmCEHrUptleZzTGTvdouBnjzEAkU2Xigloe4J1O0T7ysF-o"
 ];

let board = [];
let selectedIndex = null;
let score = 0;
let moves = 15;
let isProcessing = false; // 애니메이션 도중 클릭 방지 고정 장치

// 1. 화면 전환 기능
function navigateTo(screenId) {
document.querySelectorAll('.game-screen').forEach(screen => {
screen.classList.add('hidden');
});
document.getElementById(screenId).classList.remove('hidden');

if(screenId === 'screen-game') {
initGameGrid();
}
}

// 2. 초기 맵 세팅 (시작할 때 이미 매치된 타일이 없도록 루프 필터 적용)
function initGameGrid() {
score = 0;
moves = 15;
selectedIndex = null;
isProcessing = false;
updateUI();

do {
board = [];
for (let i = 0; i < BOARD_SIZE * BOARD_SIZE; i++) {
board.push(Math.floor(Math.random() * icons.length));
}
} while (checkMatches().length > 0);

renderBoard();
}

// 3. 화면 그리기 (렌더링)
function renderBoard() {
const grid = document.getElementById('game-grid');
grid.innerHTML = '';

board.forEach((iconId, index) => {
const tile = document.createElement('div');
tile.className = 'puzzle-tile bg-white rounded-xl shadow-sm cursor-pointer overflow-hidden flex items-center justify-center p-1 border';
if (selectedIndex === index) tile.classList.add('selected');

if (iconId !== null) {
tile.innerHTML = <img src="${icons[iconId]}" class="w-full h-full object-cover rounded-lg" alt="cat">;
} else {
tile.innerHTML = '';
}

tile.onclick = () => handleTileClick(index);
grid.appendChild(tile);
});
}

// 4. 타일 선택 및 스왑 메커니즘
function handleTileClick(index) {
if (isProcessing || moves <= 0) return;

if (selectedIndex === null) {
selectedIndex = index;
renderBoard();
} else {
if (selectedIndex === index) {
selectedIndex = null;
renderBoard();
return;
}

if (isAdjacent(selectedIndex, index)) {
isProcessing = true;
swap(selectedIndex, index);
renderBoard();

setTimeout(() => {
let matches = checkMatches();
if (matches.length > 0) {
moves--;
processMatches(matches);
} else {
// 매치가 안 되면 원래대로 되돌리기
swap(selectedIndex, index);
selectedIndex = null;
isProcessing = false;
renderBoard();
}
}, 200);
} else {
selectedIndex = index; // 인접하지 않은 곳 누르면 선택 타일 변경
renderBoard();
}
}
}

function isAdjacent(i1, i2) {
const r1 = Math.floor(i1 / BOARD_SIZE), c1 = i1 % BOARD_SIZE;
const r2 = Math.floor(i2 / BOARD_SIZE), c2 = i2 % BOARD_SIZE;
return Math.abs(r1 - r2) + Math.abs(c1 - c2) === 1;
}

function swap(i1, i2) {
const temp = board[i1];
board[i1] = board[i2];
board[i2] = temp;
}

// 5. 3매치 검사 스캐너 알고리즘
function checkMatches() {
let matchedIndices = new Set();

// 가로 스캔 (3개 연속 확인)
for (let r = 0; r < BOARD_SIZE; r++) {
for (let c = 0; c < BOARD_SIZE - 2; c++) {
let idx1 = r * BOARD_SIZE + c;
let idx2 = idx1 + 1;
let idx3 = idx1 + 2;
if (board[idx1] !== null && board[idx1] === board[idx2] && board[idx1] === board[idx3]) {
matchedIndices.add(idx1); matchedIndices.add(idx2); matchedIndices.add(idx3);
}
}
}

// 세로 스캔 (3개 연속 확인)
for (let c = 0; c < BOARD_SIZE; c++) {
for (let r = 0; r < BOARD_SIZE - 2; r++) {
let idx1 = r * BOARD_SIZE + c;
let idx2 = idx1 + BOARD_SIZE;
let idx3 = idx1 + (BOARD_SIZE * 2);
if (board[idx1] !== null && board[idx1] === board[idx2] && board[idx1] === board[idx3]) {
matchedIndices.add(idx1); matchedIndices.add(idx2); matchedIndices.add(idx3);
}
}
}
return Array.from(matchedIndices);
}

// 6. 타일 터뜨리기 및 점수 추가
function processMatches(matches) {
selectedIndex = null;

matches.forEach(idx => {
const tiles = document.querySelectorAll('.puzzle-tile');
if (tiles[idx]) createSparkle(tiles[idx]);
board[idx] = null;
});

score += matches.length * 100;
updateUI();
renderBoard();

// 터진 빈 공간 채우기 대기시간
setTimeout(() => {
dropDownAndRefill();
}, 350);
}

// 7. 중력 낙하 및 새로운 블록 리필 (콤보 연쇄 처리 포함)
function dropDownAndRefill() {
for (let c = 0; c < BOARD_SIZE; c++) {
let emptySpots = 0;
// 아래에서 위로 올라가며 빈 공간 체크
for (let r = BOARD_SIZE - 1; r >= 0; r--) {
let idx = r * BOARD_SIZE + c;
if (board[idx] === null) {
emptySpots++;
} else if (emptySpots > 0) {
board[idx + emptySpots * BOARD_SIZE] = board[idx];
board[idx] = null;
}
}
// 빈 상단칸에 무작위 신규 타일 리필
for (let r = 0; r < emptySpots; r++) {
let idx = r * BOARD_SIZE + c;
board[idx] = Math.floor(Math.random() * icons.length);
}
}

renderBoard();

// 리필된 판에서 또 터지는 매치가 있는지 연속(Combo) 확인
setTimeout(() => {
let nextMatches = checkMatches();
if (nextMatches.length > 0) {
processMatches(nextMatches);
} else {
isProcessing = false; // 모든 처리가 끝나면 클릭 고정 해제
if (moves <= 0) {
document.getElementById('final-score-val').innerText = score.toLocaleString();
navigateTo('screen-clear');
}
}
}, 300);
}

// 8. 상단 UI 동적 동기화
function updateUI() {
document.getElementById('score-val').innerText = score.toLocaleString();
document.getElementById('moves-val').innerText = moves;
}

// 별가루 파티클 효과 함수
function createSparkle(el) {
const rect = el.getBoundingClientRect();
for(let i=0; i<3; i++) {
const sparkle = document.createElement('div');
sparkle.className = 'material-symbols-outlined text-pink-400 floating-sparkle';
sparkle.style.left = (rect.left + rect.width / 2 + (Math.random()*20 - 10)) + 'px';
sparkle.style.top = (rect.top + rect.height / 2 + (Math.random()*20 - 10)) + 'px';
sparkle.style.fontSize = (14 + Math.random()*12) + 'px';
sparkle.textContent = 'auto_awesome';
document.body.appendChild(sparkle);
setTimeout(() => sparkle.remove(), 1000);
}
}
</script>
